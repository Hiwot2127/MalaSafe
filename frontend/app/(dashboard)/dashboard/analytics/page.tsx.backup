'use client';

import { useState, useMemo } from 'react';
import { Activity, Download, Sparkles, TrendingUp, TrendingDown, BarChart3, LineChart, GitCompare, Layers, Calendar } from 'lucide-react';
import { useTrends } from '@/lib/api/queries';
import { exportsApi } from '@/lib/api/exports';
import { useToast } from '@/lib/hooks/use-toast';
import type { TrendDataPoint } from '@/types/analytics';
import {
  AlertBanner,
  EditorialSelect,
  EmptyState,
  LoadingScreen,
  Metric,
  PageHeader,
  SectionHeader,
  StatCard,
} from '@/components/editorial';

type TrendType = 'weekly' | 'monthly';
type ChartType = 'line' | 'bar';
type ViewMode = 'single' | 'yoy' | 'multi-region';

const REGIONS = [
  'Addis Ababa',
  'Afar',
  'Amhara',
  'Benishangul-Gumuz',
  'Dire Dawa',
  'Gambela',
  'Harari',
  'Oromia',
  'Sidama',
  'SNNPR',
  'Somali',
  'Tigray',
];

const CURRENT_YEAR = new Date().getFullYear();
const YEARS = Array.from({ length: 5 }, (_, i) => CURRENT_YEAR - i);

const DATA_DENSITY_OPTIONS = [
  { value: 6, label: 'Last 6 months' },
  { value: 12, label: 'Last 12 months' },
  { value: 24, label: 'Last 24 months' },
  { value: 36, label: 'Last 36 months' },
];

const REGION_COLORS = [
  'hsl(var(--primary))',
  'hsl(20 56% 50%)',
  'hsl(145 22% 52%)',
  'hsl(270 50% 50%)',
];

export default function AnalyticsPage() {
  const [trendType, setTrendType] = useState<TrendType>('monthly');
  const [chartType, setChartType] = useState<ChartType>('line');
  const [viewMode, setViewMode] = useState<ViewMode>('single');
  const [selectedRegion, setSelectedRegion] = useState<string>('');
  const [selectedYear, setSelectedYear] = useState<number | undefined>(undefined);
  const [dataLimit, setDataLimit] = useState<number>(12);
  const [showForecast, setShowForecast] = useState<boolean>(false);
  const [exporting, setExporting] = useState(false);
  const [exportError, setExportError] = useState<string | null>(null);
  const [hoveredIndex, setHoveredIndex] = useState<number | null>(null);
  
  // Year-over-year comparison years
  const [yoyYear1, setYoyYear1] = useState<number>(CURRENT_YEAR);
  const [yoyYear2, setYoyYear2] = useState<number>(CURRENT_YEAR - 1);
  
  // Multi-region comparison
  const [compareRegions, setCompareRegions] = useState<string[]>([REGIONS[0]]);
  
  const { toast } = useToast();
  
  // Primary data query
  const { data, isLoading, error } = useTrends({
    trend_type: trendType,
    limit: dataLimit,
    ...(viewMode === 'single' && selectedYear ? { year: selectedYear } : {}),
    ...(viewMode === 'single' && selectedRegion ? { region: selectedRegion } : {}),
  });

  // Year-over-year queries
  const { data: yoyData1 } = useTrends({
    trend_type: trendType,
    limit: 12,
    year: yoyYear1,
    ...(selectedRegion ? { region: selectedRegion } : {}),
  });

  const { data: yoyData2 } = useTrends({
    trend_type: trendType,
    limit: 12,
    year: yoyYear2,
    ...(selectedRegion ? { region: selectedRegion } : {}),
  });

  // Multi-region queries
  const regionQueries = compareRegions.map(region => 
    // eslint-disable-next-line react-hooks/rules-of-hooks
    useTrends({
      trend_type: trendType,
      limit: dataLimit,
      region,
      ...(selectedYear ? { year: selectedYear } : {}),
    })
  );

  const trends = (data?.data ?? []) as TrendDataPoint[];
  const yoyTrends1 = (yoyData1?.data ?? []) as TrendDataPoint[];
  const yoyTrends2 = (yoyData2?.data ?? []) as TrendDataPoint[];
  const multiRegionTrends = regionQueries.map(q => (q.data?.data ?? []) as TrendDataPoint[]);

  // Calculate statistics
  const stats = useMemo(() => {
    if (trends.length === 0) return null;
    const values = trends.map(t => t.positive);
    const total = values.reduce((sum, val) => sum + val, 0);
    const avg = total / values.length;
    const max = Math.max(...values);
    const min = Math.min(...values);
    const maxPeriod = trends[values.indexOf(max)]?.period;
    const minPeriod = trends[values.indexOf(min)]?.period;
    return { total, avg, max, min, maxPeriod, minPeriod };
  }, [trends]);

  // Calculate month-over-month growth rates
  const trendsWithGrowth = useMemo(() => {
    return trends.map((trend, index) => {
      if (index === trends.length - 1) {
        return { ...trend, growthRate: null, growthValue: null };
      }
      const current = trend.positive;
      const previous = trends[index + 1].positive;
      const growthValue = current - previous;
      const growthRate = previous === 0 ? 0 : ((current - previous) / previous) * 100;
      return { ...trend, growthRate, growthValue };
    });
  }, [trends]);

  // Simple linear regression forecast
  const forecast = useMemo(() => {
    if (!showForecast || trends.length < 3) return [];
    
    const n = trends.length;
    const xValues = trends.map((_, i) => i);
    const yValues = trends.map(t => t.positive);
    
    const sumX = xValues.reduce((a, b) => a + b, 0);
    const sumY = yValues.reduce((a, b) => a + b, 0);
    const sumXY = xValues.reduce((sum, x, i) => sum + x * yValues[i], 0);
    const sumXX = xValues.reduce((sum, x) => sum + x * x, 0);
    
    const slope = (n * sumXY - sumX * sumY) / (n * sumXX - sumX * sumX);
    const intercept = (sumY - slope * sumX) / n;
    
    // Forecast next 3 periods
    const forecastPoints = [];
    for (let i = 1; i <= 3; i++) {
      const x = n + i - 1;
      const predicted = Math.max(0, slope * x + intercept);
      forecastPoints.push(predicted);
    }
    
    return forecastPoints;
  }, [trends, showForecast]);

  const seriesMax = useMemo(() => {
    const dataMax = trends.reduce((m: number, t: TrendDataPoint) => Math.max(m, t.positive), 0);
    const forecastMax = forecast.length > 0 ? Math.max(...forecast) : 0;
    return Math.max(dataMax, forecastMax);
  }, [trends, forecast]);
  
  const buildPoints = (data: TrendDataPoint[], key: 'positive') =>
    data.length
      ? data
        .slice()
        .reverse()
        .map((t: TrendDataPoint, i: number) => {
          const x = (i / Math.max(data.length - 1, 1)) * 100;
          const y = seriesMax === 0 ? 50 : 50 - (t[key] / seriesMax) * 45;
          return `${x.toFixed(2)},${y.toFixed(2)}`;
        })
        .join(' ')
      : '';
  
  const casesPoints = buildPoints(trends, 'positive');

  // Build forecast points
  const forecastPoints = useMemo(() => {
    if (forecast.length === 0 || trends.length === 0) return '';
    const startX = 100;
    const step = 100 / Math.max(trends.length - 1, 1);
    return forecast.map((value, i) => {
      const x = startX + (i + 1) * step;
      const y = seriesMax === 0 ? 50 : 50 - (value / seriesMax) * 45;
      return `${x.toFixed(2)},${y.toFixed(2)}`;
    }).join(' ');
  }, [forecast, trends.length, seriesMax]);

  // Year-over-year comparison stats
  const yoyComparison = useMemo(() => {
    if (yoyTrends1.length === 0 || yoyTrends2.length === 0) return null;
    const total1 = yoyTrends1.reduce((sum, t) => sum + t.positive, 0);
    const total2 = yoyTrends2.reduce((sum, t) => sum + t.positive, 0);
    const change = total1 - total2;
    const changePercent = total2 === 0 ? 0 : (change / total2) * 100;
    return { total1, total2, change, changePercent };
  }, [yoyTrends1, yoyTrends2]);

  const handleAddRegion = () => {
    const available = REGIONS.filter(r => !compareRegions.includes(r));
    if (available.length > 0 && compareRegions.length < 4) {
      setCompareRegions([...compareRegions, available[0]]);
    }
  };

  const handleRemoveRegion = (index: number) => {
    if (compareRegions.length > 1) {
      setCompareRegions(compareRegions.filter((_, i) => i !== index));
    }
  };

  const handleRegionChange = (index: number, newRegion: string) => {
    const updated = [...compareRegions];
    updated[index] = newRegion;
    setCompareRegions(updated);
  };

  const handleExport = async () => {
    try {
      setExporting(true);
      setExportError(null);
      const filename = await exportsApi.downloadAnalyticsSummary();
      toast({
        title: 'Report downloaded',
        description: `${filename} has been saved to your downloads folder.`,
        variant: 'success',
      });
    } catch (err) {
      const maybe = err as { response?: { data?: { detail?: string } }; message?: string };
      const errorMsg = maybe.response?.data?.detail || maybe.message || 'Failed to export PDF summary';
      setExportError(errorMsg);
      toast({
        title: 'Export failed',
        description: errorMsg,
        variant: 'destructive',
      });
    } finally {
      setExporting(false);
    }
  };

  return (
    <div className="mx-auto flex max-w-6xl flex-col gap-14 animate-fade-in">
      <PageHeader
        eyebrow="MalaSafe · Trends"
        title="Analytics"
        description={
          trendType === 'weekly'
            ? 'Week-over-week case movement. (Weekly view is planned — the current data pipeline is monthly-only.)'
            : 'Month-over-month case movement. Cases are aggregated from the monthly malaria CSV uploads (columns: positive, tests, travel).'
        }
        actions={
          <button
            type="button"
            onClick={handleExport}
            disabled={exporting}
            aria-label={exporting ? 'Exporting analytics summary PDF' : 'Export analytics summary PDF'}
            className="inline-flex items-center gap-2 rounded-full border border-border/60 bg-background px-4 py-2 font-mono text-[11px] uppercase tracking-[0.18em] text-foreground transition-colors hover:border-foreground/60 hover:bg-secondary/50 disabled:cursor-not-allowed disabled:opacity-50"
          >
            <Download className="size-3.5" strokeWidth={1.75} aria-hidden />
            {exporting ? 'Exporting PDF…' : 'Export PDF'}
          </button>
        }
      />

      {exportError ? (
        <AlertBanner tone="error" title="Couldn't export PDF" description={exportError} />
      ) : null}

      {/* View Mode Selector */}
      {trendType === 'monthly' && (
        <section className="flex flex-col gap-4">
          <div className="flex flex-wrap items-center gap-3">
            <span className="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">
              View Mode:
            </span>
            <button
              type="button"
              onClick={() => setViewMode('single')}
              className={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] transition-colors ${
                viewMode === 'single'
                  ? 'border-primary bg-primary text-primary-foreground'
                  : 'border-border/60 bg-background text-foreground hover:border-foreground/60 hover:bg-secondary/50'
              }`}
            >
              <Activity className="size-3" strokeWidth={2} />
              Single View
            </button>
            <button
              type="button"
              onClick={() => setViewMode('yoy')}
              className={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] transition-colors ${
                viewMode === 'yoy'
                  ? 'border-primary bg-primary text-primary-foreground'
                  : 'border-border/60 bg-background text-foreground hover:border-foreground/60 hover:bg-secondary/50'
              }`}
            >
              <GitCompare className="size-3" strokeWidth={2} />
              Year Comparison
            </button>
            <button
              type="button"
              onClick={() => setViewMode('multi-region')}
              className={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] transition-colors ${
                viewMode === 'multi-region'
                  ? 'border-primary bg-primary text-primary-foreground'
                  : 'border-border/60 bg-background text-foreground hover:border-foreground/60 hover:bg-secondary/50'
              }`}
            >
              <Layers className="size-3" strokeWidth={2} />
              Region Comparison
            </button>
          </div>

          {/* Single View Filters */}
          {viewMode === 'single' && (
            <div className="flex flex-wrap items-center gap-3">
              <EditorialSelect
                value={selectedRegion}
                onChange={setSelectedRegion}
                aria-label="Region filter"
                options={[
                  { value: '', label: 'All regions' },
                  ...REGIONS.map((r) => ({ value: r, label: r })),
                ]}
              />
              <EditorialSelect
                value={selectedYear?.toString() ?? ''}
                onChange={(val) => setSelectedYear(val ? parseInt(val) : undefined)}
                aria-label="Year filter"
                options={[
                  { value: '', label: 'All years' },
                  ...YEARS.map((y) => ({ value: y.toString(), label: y.toString() })),
                ]}
              />
              <EditorialSelect
                value={dataLimit.toString()}
                onChange={(val) => setDataLimit(parseInt(val))}
                aria-label="Data density"
                options={DATA_DENSITY_OPTIONS.map(opt => ({ value: opt.value.toString(), label: opt.label }))}
              />
              <div className="flex items-center gap-2 ml-auto">
                <button
                  type="button"
                  onClick={() => setShowForecast(!showForecast)}
                  className={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] transition-colors ${
                    showForecast
                      ? 'border-primary bg-primary/10 text-primary'
                      : 'border-border/60 bg-background text-foreground hover:border-foreground/60 hover:bg-secondary/50'
                  }`}
                >
                  <TrendingUp className="size-3" strokeWidth={2} />
                  {showForecast ? 'Forecast On' : 'Forecast Off'}
                </button>
                <button
                  type="button"
                  onClick={() => setChartType('line')}
                  aria-pressed={chartType === 'line'}
                  className={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] transition-colors ${
                    chartType === 'line'
                      ? 'border-primary bg-primary text-primary-foreground'
                      : 'border-border/60 bg-background text-foreground hover:border-foreground/60 hover:bg-secondary/50'
                  }`}
                >
                  <LineChart className="size-3" strokeWidth={2} />
                  Line
                </button>
                <button
                  type="button"
                  onClick={() => setChartType('bar')}
                  aria-pressed={chartType === 'bar'}
                  className={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] transition-colors ${
                    chartType === 'bar'
                      ? 'border-primary bg-primary text-primary-foreground'
                      : 'border-border/60 bg-background text-foreground hover:border-foreground/60 hover:bg-secondary/50'
                  }`}
                >
                  <BarChart3 className="size-3" strokeWidth={2} />
                  Bar
                </button>
              </div>
            </div>
          )}

          {/* Year-over-Year Filters */}
          {viewMode === 'yoy' && (
            <div className="flex flex-wrap items-center gap-3">
              <EditorialSelect
                value={yoyYear1.toString()}
                onChange={(val) => setYoyYear1(parseInt(val))}
                aria-label="First year"
                options={YEARS.map((y) => ({ value: y.toString(), label: y.toString() }))}
              />
              <span className="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">vs</span>
              <EditorialSelect
                value={yoyYear2.toString()}
                onChange={(val) => setYoyYear2(parseInt(val))}
                aria-label="Second year"
                options={YEARS.map((y) => ({ value: y.toString(), label: y.toString() }))}
              />
              <EditorialSelect
                value={selectedRegion}
                onChange={setSelectedRegion}
                aria-label="Region filter"
                options={[
                  { value: '', label: 'All regions' },
                  ...REGIONS.map((r) => ({ value: r, label: r })),
                ]}
              />
            </div>
          )}

          {/* Multi-Region Filters */}
          {viewMode === 'multi-region' && (
            <div className="flex flex-col gap-3">
              {compareRegions.map((region, index) => (
                <div key={index} className="flex items-center gap-2">
                  <span 
                    className="inline-block size-3 rounded-full" 
                    style={{ backgroundColor: REGION_COLORS[index] }}
                    aria-hidden
                  />
                  <EditorialSelect
                    value={region}
                    onChange={(val) => handleRegionChange(index, val)}
                    aria-label={`Region ${index + 1}`}
                    options={REGIONS.map((r) => ({ value: r, label: r }))}
                  />
                  {compareRegions.length > 1 && (
                    <button
                      type="button"
                      onClick={() => handleRemoveRegion(index)}
                      className="rounded-full border border-border/60 bg-background px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-foreground transition-colors hover:border-status-error hover:text-status-error"
                    >
                      Remove
                    </button>
                  )}
                </div>
              ))}
              {compareRegions.length < 4 && (
                <button
                  type="button"
                  onClick={handleAddRegion}
                  className="inline-flex w-fit items-center gap-1.5 rounded-full border border-border/60 bg-background px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-foreground transition-colors hover:border-primary hover:text-primary"
                >
                  + Add Region
                </button>
              )}
              <div className="flex items-center gap-2">
                <EditorialSelect
                  value={dataLimit.toString()}
                  onChange={(val) => setDataLimit(parseInt(val))}
                  aria-label="Data density"
                  options={DATA_DENSITY_OPTIONS.map(opt => ({ value: opt.value.toString(), label: opt.label }))}
                />
              </div>
            </div>
          )}
        </section>
      )}

      {/* Statistics Cards */}
      {trendType === 'monthly' && viewMode === 'single' && stats && (
        <section className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 animate-in fade-in slide-in-from-bottom-4 duration-700 fill-mode-both delay-100">
          <div className="glass-panel rounded-2xl overflow-hidden p-1">
            <StatCard
              eyebrow="Total cases"
              value={stats.total.toLocaleString()}
              caption={`Sum across ${trends.length} month${trends.length === 1 ? '' : 's'}`}
              icon={Activity}
              tone="signal"
            />
          </div>
          <div className="glass-panel rounded-2xl overflow-hidden p-1">
            <StatCard
              eyebrow="Average per month"
              value={Math.round(stats.avg).toLocaleString()}
              caption={`Mean of ${trends.length} periods`}
              icon={Sparkles}
            />
          </div>
          <div className="glass-panel rounded-2xl overflow-hidden p-1">
            <StatCard
              eyebrow="Peak month"
              value={stats.max.toLocaleString()}
              caption={stats.maxPeriod || 'N/A'}
              icon={TrendingUp}
              tone="error"
            />
          </div>
          <div className="glass-panel rounded-2xl overflow-hidden p-1">
            <StatCard
              eyebrow="Lowest month"
              value={stats.min.toLocaleString()}
              caption={stats.minPeriod || 'N/A'}
              icon={TrendingDown}
              tone="valid"
            />
          </div>
        </section>
      )}

      {/* Year-over-Year Comparison Stats */}
      {trendType === 'monthly' && viewMode === 'yoy' && yoyComparison && (
        <section className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div className="glass-panel rounded-2xl overflow-hidden p-1">
            <StatCard
              eyebrow={`${yoyYear1} Total`}
              value={yoyComparison.total1.toLocaleString()}
              caption="Most recent year"
              icon={Calendar}
              tone="signal"
            />
          </div>
          <div className="glass-panel rounded-2xl overflow-hidden p-1">
            <StatCard
              eyebrow={`${yoyYear2} Total`}
              value={yoyComparison.total2.toLocaleString()}
              caption="Previous year"
              icon={Calendar}
            />
          </div>
          <div className="glass-panel rounded-2xl overflow-hidden p-1">
            <StatCard
              eyebrow="Year-over-Year Change"
              value={`${yoyComparison.changePercent > 0 ? '+' : ''}${yoyComparison.changePercent.toFixed(1)}%`}
              caption={`${yoyComparison.change > 0 ? '+' : ''}${yoyComparison.change.toLocaleString()} cases`}
              icon={yoyComparison.changePercent > 0 ? TrendingUp : TrendingDown}
              tone={yoyComparison.changePercent > 0 ? 'error' : 'valid'}
            />
          </div>
        </section>
      )}

      <section className="flex flex-col gap-5 animate-fade-in-up" style={{ animationDelay: '200ms' }}>
        <SectionHeader
          index="001"
          label={trendType === 'weekly' ? 'Weekly series' : 'Monthly series'}
          tone="signal"
        >
          <EditorialSelect
            value={trendType}
            onChange={(next) => setTrendType(next as TrendType)}
            aria-label="Trend type"
            options={[
              { value: 'weekly', label: 'Weekly' },
              { value: 'monthly', label: 'Monthly' },
            ]}
          />
        </SectionHeader>

        {trendType === 'weekly' ? (
          <AlertBanner
            tone="info"
            title="Weekly view coming soon"
            description="The malaria reporting pipeline currently ingests monthly aggregates only. Weekly (ISO-week) granularity is planned for a future update — switch to Monthly above for the current view."
          />
        ) : isLoading ? (
          <LoadingScreen caption="Loading series" />
        ) : error ? (
          <AlertBanner tone="error" title="Couldn't load trends" description={(error as Error).message} />
        ) : trends.length === 0 ? (
          <EmptyState
            title="No trend data available"
            description="Upload a monthly malaria CSV to seed the trend series."
          />
        ) : (
          <>
            {/* Enhanced Chart */}
            <div className="glass-panel rounded-2xl overflow-hidden border border-border/40 shadow-lg">
              <div className="flex flex-col gap-4 bg-background/40 backdrop-blur-md p-6 group">
                <div className="flex items-center justify-between">
                  <p className="font-mono text-[11px] uppercase tracking-[0.20em] text-muted-foreground">
                    Cases · oldest → most recent
                  </p>
                  <p className="font-mono text-[11px] uppercase tracking-[0.20em] text-primary tabular-nums">
                    {trends.length} mo
                  </p>
                </div>
                
                {/* Interactive Chart */}
                <div 
                  className="relative h-64 w-full mt-2"
                  onMouseLeave={() => setHoveredIndex(null)}
                >
                  {chartType === 'line' ? (
                    <svg
                      viewBox="0 0 100 50"
                      preserveAspectRatio="none"
                      className="h-full w-full overflow-visible"
                      aria-hidden
                    >
                      {/* Grid lines */}
                      <line x1="0" y1="12.5" x2="100" y2="12.5" stroke="hsl(var(--border))" strokeWidth="0.3" opacity="0.3" />
                      <line x1="0" y1="25" x2="100" y2="25" stroke="hsl(var(--border))" strokeWidth="0.3" opacity="0.3" />
                      <line x1="0" y1="37.5" x2="100" y2="37.5" stroke="hsl(var(--border))" strokeWidth="0.3" opacity="0.3" />
                      <line x1="0" y1="49.5" x2="100" y2="49.5" stroke="hsl(var(--border))" strokeWidth="0.5" />
                      
                      {/* Area fill */}
                      <path
                        d={`M0,50 L${casesPoints} L100,50 Z`}
                        fill="url(#trend-gradient)"
                        opacity="0.15"
                      />
                      
                      {/* Line */}
                      <polyline
                        fill="none"
                        stroke="currentColor"
                        className="text-primary"
                        strokeWidth="2.5"
                        points={casesPoints}
                        vectorEffect="non-scaling-stroke"
                        strokeLinecap="round"
                        strokeLinejoin="round"
                      />
                      
                      {/* Interactive points */}
                      {trends.slice().reverse().map((trend, i) => {
                        const x = (i / Math.max(trends.length - 1, 1)) * 100;
                        const y = seriesMax === 0 ? 50 : 50 - (trend.positive / seriesMax) * 45;
                        const isHovered = hoveredIndex === trends.length - 1 - i;
                        return (
                          <g key={i}>
                            <circle
                              cx={x}
                              cy={y}
                              r={isHovered ? "1.5" : "0.8"}
                              fill="currentColor"
                              className={isHovered ? "text-primary" : "text-primary/60"}
                              style={{ transition: 'all 0.2s' }}
                            />
                            <circle
                              cx={x}
                              cy={y}
                              r="3"
                              fill="transparent"
                              style={{ cursor: 'pointer' }}
                              onMouseEnter={() => setHoveredIndex(trends.length - 1 - i)}
                            />
                          </g>
                        );
                      })}
                      
                      <defs>
                        <linearGradient id="trend-gradient" x1="0" x2="0" y1="0" y2="1">
                          <stop offset="0%" stopColor="currentColor" className="text-primary" />
                          <stop offset="100%" stopColor="transparent" />
                        </linearGradient>
                      </defs>
                    </svg>
                  ) : (
                    <svg
                      viewBox="0 0 100 50"
                      preserveAspectRatio="none"
                      className="h-full w-full overflow-visible"
                      aria-hidden
                    >
                      {/* Grid lines */}
                      <line x1="0" y1="12.5" x2="100" y2="12.5" stroke="hsl(var(--border))" strokeWidth="0.3" opacity="0.3" />
                      <line x1="0" y1="25" x2="100" y2="25" stroke="hsl(var(--border))" strokeWidth="0.3" opacity="0.3" />
                      <line x1="0" y1="37.5" x2="100" y2="37.5" stroke="hsl(var(--border))" strokeWidth="0.3" opacity="0.3" />
                      <line x1="0" y1="49.5" x2="100" y2="49.5" stroke="hsl(var(--border))" strokeWidth="0.5" />
                      
                      {/* Bars */}
                      {trends.slice().reverse().map((trend, i) => {
                        const barWidth = 100 / trends.length * 0.7;
                        const x = (i / trends.length) * 100 + (100 / trends.length - barWidth) / 2;
                        const height = seriesMax === 0 ? 0 : (trend.positive / seriesMax) * 45;
                        const y = 50 - height;
                        const isHovered = hoveredIndex === trends.length - 1 - i;
                        return (
                          <rect
                            key={i}
                            x={x}
                            y={y}
                            width={barWidth}
                            height={height}
                            fill="currentColor"
                            className={isHovered ? "text-primary" : "text-primary/80"}
                            style={{ cursor: 'pointer', transition: 'all 0.2s' }}
                            onMouseEnter={() => setHoveredIndex(trends.length - 1 - i)}
                          />
                        );
                      })}
                    </svg>
                  )}
                  
                  {/* Tooltip */}
                  {hoveredIndex !== null && trends[hoveredIndex] && (
                    <div className="absolute top-2 left-1/2 -translate-x-1/2 z-10 rounded-lg border border-primary/20 bg-background/95 backdrop-blur-xl px-4 py-2.5 shadow-xl">
                      <p className="font-mono text-[10px] uppercase tracking-[0.18em] text-muted-foreground">
                        {trends[hoveredIndex].period}
                      </p>
                      <p className="font-display text-2xl font-bold text-primary tabular-nums">
                        {trends[hoveredIndex].positive.toLocaleString()}
                      </p>
                      <p className="font-mono text-[10px] text-muted-foreground">
                        cases reported
                      </p>
                    </div>
                  )}
                </div>
                
                <div className="flex items-center gap-5 font-mono text-[11px] uppercase tracking-[0.20em] text-muted-foreground">
                  <span className="inline-flex items-center gap-2">
                    <span aria-hidden className="inline-block size-2.5 rounded-full bg-primary shadow-[0_0_8px_rgba(var(--primary-rgb),0.8)]" />
                    Cases
                  </span>
                </div>
                <div className="flex items-center justify-between font-mono text-[11px] uppercase tracking-[0.20em] text-muted-foreground tabular-nums">
                  <span>{trends[trends.length - 1]?.period ?? '-'}</span>
                  <span>{trends[0]?.period ?? '-'}</span>
                </div>
              </div>
            </div>

            <SectionHeader index="002" label="Periods" tone="signal">
              <span className="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground tabular-nums">
                {trends.length} rows
              </span>
            </SectionHeader>
            <div className="overflow-hidden rounded-2xl glass-panel border border-border/40 mt-2 shadow-lg">
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead>
                    <tr className="border-b border-border/40">
                      <Th>Period</Th>
                      <Th>Year</Th>
                      <Th align="right">Cases</Th>
                      <Th align="right">Change</Th>
                      <Th align="right">Growth %</Th>
                    </tr>
                  </thead>
                  <tbody>
                    {trendsWithGrowth.map((trend, index: number) => {
                      const isPositiveGrowth = trend.growthRate !== null && trend.growthRate > 0;
                      const isNegativeGrowth = trend.growthRate !== null && trend.growthRate < 0;
                      return (
                        <tr
                          key={index}
                          className="group border-b border-border/40 transition-all duration-300 last:border-0 hover:bg-primary/5 hover:shadow-[0_0_15px_rgba(var(--primary-rgb),0.1)] cursor-pointer"
                        >
                          <Td>{trend.period}</Td>
                          <Td>{trend.year}</Td>
                          <Td align="right" numeric>
                            <span className="font-medium text-foreground group-hover:text-primary transition-colors">
                              {trend.positive.toLocaleString()}
                            </span>
                          </Td>
                          <Td align="right" numeric>
                            {trend.growthValue !== null ? (
                              <span className={isPositiveGrowth ? 'text-status-error' : isNegativeGrowth ? 'text-status-valid' : 'text-muted-foreground'}>
                                {trend.growthValue > 0 ? '+' : ''}{trend.growthValue.toLocaleString()}
                              </span>
                            ) : (
                              <span className="text-muted-foreground">—</span>
                            )}
                          </Td>
                          <Td align="right" numeric>
                            {trend.growthRate !== null ? (
                              <div className="inline-flex items-center gap-1.5">
                                {isPositiveGrowth && <TrendingUp className="size-3 text-status-error" strokeWidth={2} />}
                                {isNegativeGrowth && <TrendingDown className="size-3 text-status-valid" strokeWidth={2} />}
                                <span className={isPositiveGrowth ? 'text-status-error' : isNegativeGrowth ? 'text-status-valid' : 'text-muted-foreground'}>
                                  {trend.growthRate > 0 ? '+' : ''}{trend.growthRate.toFixed(1)}%
                                </span>
                              </div>
                            ) : (
                              <span className="text-muted-foreground">—</span>
                            )}
                          </Td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          </>
        )}
      </section>
    </div>
  );
}

function Th({
  children,
  align = 'left',
}: {
  children: React.ReactNode;
  align?: 'left' | 'right';
}) {
  return (
    <th
      className={`px-4 py-3 font-mono text-[10px] font-medium uppercase tracking-[0.22em] text-muted-foreground ${align === 'right' ? 'text-right' : 'text-left'
        }`}
    >
      {children}
    </th>
  );
}

function Td({
  children,
  align = 'left',
  numeric = false,
}: {
  children: React.ReactNode;
  align?: 'left' | 'right';
  numeric?: boolean;
}) {
  return (
    <td
      className={`px-4 py-3 font-sans text-sm text-foreground ${align === 'right' ? 'text-right' : 'text-left'
        } ${numeric ? 'font-mono tabular-nums' : ''}`}
    >
      {children}
    </td>
  );
}
