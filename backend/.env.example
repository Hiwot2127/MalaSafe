# Copy to .env and fill in. For Render prod, see .env.render.local.

APP_NAME=MalaSafe API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

HOST=0.0.0.0
PORT=8000

# Local Postgres (default). For Supabase pooler: use postgres.<PROJECT_REF>
# user, URL-encode password (/ %2F, $ %24, @ %40), asyncpg=?ssl=require,
# psycopg2=?sslmode=require.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/malasafe_db
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/malasafe_db

# Generate: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

MODEL_PATH=./models

LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Production Hardening - Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_CACHE=2
REDIS_DB_RATE_LIMIT=0
REDIS_DB_CELERY=1

# Production Hardening - Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Production Hardening - Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Production Hardening - Security
REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_ENABLED=true
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
