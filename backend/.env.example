# MalaSafe API - canonical environment template
#
# Copy this file to .env (gitignored) and fill in the values for your setup.
# Two database options are documented below - pick one.
#
# Companion files in this directory:
#   .env                      your active local config (gitignored)
#   .env.render.example       Render production template (Supabase + Render conventions)
#   .env.render.local         filled production values, paste into Render UI (gitignored)


# ---- Runtime ----
APP_NAME=MalaSafe API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Database -----------------------------------------------------------
# Pick ONE of the two blocks below. Comment the other out.
#
# Option A - Local Postgres (development default)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/malasafe_db
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/malasafe_db
#
# Option B - Supabase (Session Pooler, port 5432, never 6543)
#   - Hostname is `aws-<N>-<region>.pooler.supabase.com` where N is 0 or 1
#     depending on your project's region. Get the exact one from Supabase
#     dashboard > Project Settings > Database > Connection string > Session pooler.
#   - User must be `postgres.<PROJECT_REF>` (project ref appended).
#   - URL-encode special chars in password (/ -> %2F, $ -> %24, @ -> %40, # -> %23).
#   - The two drivers want DIFFERENT SSL keys:
#       asyncpg  -> ?ssl=require
#       psycopg2 -> ?sslmode=require
# DATABASE_URL=postgresql+asyncpg://postgres.<PROJECT_REF>:<ENCODED_PW>@aws-<N>-<REGION>.pooler.supabase.com:5432/postgres?ssl=require
# DATABASE_URL_SYNC=postgresql://postgres.<PROJECT_REF>:<ENCODED_PW>@aws-<N>-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require

# ---- JWT ----
# Generate a unique value with:  openssl rand -hex 32
# Never reuse the production SECRET_KEY locally - separate keys per environment.
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- CORS ----
# Origin format: scheme + host (no path, no trailing slash). Browsers send
# Origin as `https://example.com` - match exactly.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ---- Redis / Celery (optional; only needed for monthly forward-prediction job) ----
REDIS_URL=redis://localhost:6379/0

# ---- File uploads ----
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# ---- AI model artifacts ----
# Path to the LightGBM boosters + risk_thresholds.json + regional_baselines.json.
# Default ./models resolves relative to the backend/ working directory.
MODEL_PATH=./models
MODEL_VERSION=1.0.0

# ---- SMTP (optional, unused in core MVP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@malasafe.com

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
