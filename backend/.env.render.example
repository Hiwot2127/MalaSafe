# MalaSafe API — Render production env template (Supabase-backed)
#
# Paste these into Render dashboard > Web Service > Environment.
# Replace every <PLACEHOLDER>. Filled version goes in .env.render.local
# (gitignored by `.env*.local` rule).
#
# Field order matches .env.example exactly. Only the values differ.


# ---- Runtime ----
PYTHON_VERSION=3.11.9
APP_NAME=MalaSafe API
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# ---- Server (Render injects $PORT — do not hardcode it) ----
HOST=0.0.0.0
# PORT  intentionally omitted; Render provides $PORT at runtime.

# ---- Database (Supabase Session Pooler, port 5432) -----------------------
# Three things people get wrong here:
#   1. Hostname is `aws-<N>-<REGION>.pooler.supabase.com` — N varies by region.
#      For eu-north-1 it's aws-1; many other regions are aws-0. Confirm in
#      Supabase dashboard > Project Settings > Database > Connection string.
#   2. User MUST be `postgres.<PROJECT_REF>` (project ref appended). Bare
#      `postgres` returns "tenant or user not found".
#   3. URL-encode special chars in password (/ -> %2F, $ -> %24, @ -> %40,
#      # -> %23). Without this, asyncpg parses `/` as path separator.
#   4. Drivers want DIFFERENT SSL query keys:
#        asyncpg  -> ?ssl=require
#        psycopg2 -> ?sslmode=require
#      Mixing them = "unknown keyword argument" crash on startup.
DATABASE_URL=postgresql+asyncpg://postgres.<PROJECT_REF>:<ENCODED_PW>@aws-<N>-<REGION>.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_URL_SYNC=postgresql://postgres.<PROJECT_REF>:<ENCODED_PW>@aws-<N>-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require

# ---- JWT ----
# Generate with: openssl rand -hex 32
# MUST be unique per environment. Never share between local and prod.
SECRET_KEY=<GENERATED_64_CHAR_HEX>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- CORS ----
# List every frontend origin that will hit this API. Browsers send Origin
# as scheme+host with no path and no trailing slash — match exactly.
# Include both http and https variants of the frontend during early testing.
CORS_ORIGINS=["http://localhost:3000","https://<FRONTEND_HOST>","http://<FRONTEND_HOST>"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ---- Redis / Celery (optional) ----
# Render free tier has no Redis. Leave unset for the free deploy — the
# monthly forward-prediction beat won't run, but the API works fine.
# When you're ready, use Upstash Redis free tier (10k commands/day):
#   REDIS_URL=rediss://default:<TOKEN>@<HOST>.upstash.io:6379

# ---- File uploads ----
# Render free disk is ephemeral — uploads vanish on each deploy/restart.
# For persistent storage, use Supabase Storage or S3 and proxy through here.
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# ---- AI model artifacts ----
MODEL_PATH=./models
MODEL_VERSION=1.0.0

# ---- SMTP (optional, unused in core MVP) ----
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@malasafe.com

# ---- Logging ----
# Render captures stdout — do NOT set LOG_FILE in production.
LOG_LEVEL=INFO
