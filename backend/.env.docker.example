# MalaSafe Backend Environment Configuration
# Copy this file to .env.production for production deployment
# For development, docker-compose.yml provides these values

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=MalaSafe API
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Async connection for FastAPI
DATABASE_URL=postgresql+asyncpg://malasafe:YOUR_POSTGRES_PASSWORD@postgres:5432/malasafe

# Sync connection for Alembic migrations
DATABASE_URL_SYNC=postgresql://malasafe:YOUR_POSTGRES_PASSWORD@postgres:5432/malasafe

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a secure secret key: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB_CACHE=2
REDIS_DB_RATE_LIMIT=0
REDIS_DB_CELERY=1

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_BROKER_URL=redis://:your-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:your-redis-password@redis:6379/1

# ============================================
# SENTRY MONITORING (Optional)
# ============================================
# Get your DSN from https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=["https://your-frontend-domain.com","https://www.your-frontend-domain.com"]
CORS_ALLOW_CREDENTIALS=true

# ============================================
# FEATURE FLAGS
# ============================================
RATE_LIMIT_ENABLED=true
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
MONTHLY_CLOSE_ENABLED=true
MONTHLY_CLOSE_MAX_MONTHS=2
MONTHLY_CLOSE_MIN_DISTRICTS=50

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# ============================================
# AI MODEL CONFIGURATION
# ============================================
MODEL_PATH=./models
MODEL_VERSION=1.0.0

# ============================================
# CLIMATE DATA PIPELINE (Optional)
# ============================================
SHAPEFILE_PATH=./data/shapefiles/eth_woreda/eth_admbnda_adm3_csa_bofedb_2021.shp
RASTER_CACHE_DIR=./data/cache/raw_rasters
CHIRPS_PROVISIONAL_DAYS=90

# Copernicus CDS API (optional - can use ~/.cdsapirc instead)
CDSAPI_URL=
CDSAPI_KEY=

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@malasafe.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
